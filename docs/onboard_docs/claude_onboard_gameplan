## 11. NOTIFICATION API ROUTE — `app/api/webhooks/step-completed/route.ts`

This is called by a Supabase Database Webhook configured on `step_progress` table (on UPDATE where `completed` changes to `true`).

```ts
import { NextRequest, NextResponse } from 'next/server'
import { adminClient } from '@/lib/supabase/admin'
import { Resend } from 'resend'

const resend = new Resend(process.env.RESEND_API_KEY)

export async function POST(req: NextRequest) {
  const payload = await req.json()
  const { record } = payload // Supabase webhook payload
  
  if (!record.completed) return NextResponse.json({ skipped: true })
  
  // Look up org and rep
  const { data: org } = await adminClient
    .from('orgs')
    .select('name, slug, assigned_rep, staff:assigned_rep(name, email, notify_email)')
    .eq('id', record.org_id)
    .single()
  
  if (!org?.staff?.notify_email) return NextResponse.json({ skipped: true })
  
  // Look up step title from template
  const { data: orgFull } = await adminClient
    .from('orgs')
    .select('template:template_id(steps)')
    .eq('id', record.org_id)
    .single()
  
  const stepTitle = orgFull?.template?.steps?.[record.step_index]?.title ?? `Step ${record.step_index + 1}`
  
  await resend.emails.send({
    from: 'Bond Onboarding <onboarding@yourdomain.com>',
    to: org.staff.email,
    subject: `✅ ${org.name} completed: ${stepTitle}`,
    html: `<p><strong>${org.name}</strong> just completed <strong>${stepTitle}</strong>.</p>
           <p><a href="${process.env.NEXT_PUBLIC_APP_URL}/admin/orgs/${record.org_id}">View progress →</a></p>`,
  })
  
  return NextResponse.json({ sent: true })
}
```

