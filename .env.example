# Copy to `.env.local` and adjust. Never commit `.env.local`.
# Run `npm run check:env` to verify your environment. See docs/environments.md
# for the full environment matrix (local / preview-staging / production).

# --- Supabase (REQUIRED — which database this deployment targets) ---
# Without these the app currently falls back to the hardcoded PRODUCTION
# project; that fallback is deprecated and will be removed in the next release.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY
# Server-side privileged key. `SUPABASE_SERVICE_KEY` is accepted as an alias.
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY

# --- Cache (Upstash / Vercel KV) ---
# Omit locally to use the in-process memory cache. Staging must point at its
# OWN KV database, never the production one.
# KV_REST_API_URL=https://YOUR-KV.upstash.io
# KV_REST_API_TOKEN=YOUR-KV-TOKEN

# --- Analytics ---
# Bond system GTM container. Use a staging container (or leave empty) off-prod.
# NEXT_PUBLIC_BOND_GTM_ID=GTM-XXXXXXX

# --- Bond host shell ---
# Override for the Bond consumer origin used by the host-shell bootstrap.
# NEXT_PUBLIC_BOND_CONSUMER_ORIGIN=https://consumer.bondsports.co

# Skip Google sign-in for `/admin` while running `next dev` only (production builds ignore this).
NEXT_PUBLIC_ADMIN_AUTH_BYPASS=true

# Required when bypass is off:
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# NEXTAUTH_SECRET=
# NEXTAUTH_URL=http://localhost:3000

# Signs httpOnly cookies for password-protected /reservations/[slug] pages (required in production when a viewer password is set).
# RESERVATION_PAGE_ACCESS_SECRET=

# Signs httpOnly cookies for TV Monitor studio access links (/tvmonitor/studio).
# Falls back to RESERVATION_PAGE_ACCESS_SECRET if unset; required in production for external builder access.
# TVMONITOR_ACCESS_SECRET=

# Sends TV Monitor studio magic-link sign-in emails (https://resend.com API key).
# Optional: without it, admins hand out copyable single-use invite links instead.
# RESEND_API_KEY=
# TVMONITOR_EMAIL_FROM="Bond Sports <no-reply@bondsports.co>"

# Customer Health key-dates webhook (shared secret with cs.bondsports.co).
# KEY_DATES_WEBHOOK_SECRET=
# KEY_DATES_WEBHOOK_URL=https://cs.bondsports.co/api/webhooks/key-dates

# Vercel cron bearer for /api/cron/* routes.
# CRON_SECRET=
