# Copy to `.env.local` and adjust. Never commit `.env.local`.

# Skip Google sign-in for `/admin` while running `next dev` only (production builds ignore this).
NEXT_PUBLIC_ADMIN_AUTH_BYPASS=true

# Required when bypass is off:
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# NEXTAUTH_SECRET=
# NEXTAUTH_URL=http://localhost:3000

# Signs httpOnly cookies for password-protected /reservations/[slug] pages (required in production when a viewer password is set).
# RESERVATION_PAGE_ACCESS_SECRET=

# Customer Health key-dates webhook (shared secret with cs.bondsports.co).
# KEY_DATES_WEBHOOK_SECRET=
# KEY_DATES_WEBHOOK_URL=https://cs.bondsports.co/api/webhooks/key-dates

# Vercel cron bearer for /api/cron/* routes.
# CRON_SECRET=
